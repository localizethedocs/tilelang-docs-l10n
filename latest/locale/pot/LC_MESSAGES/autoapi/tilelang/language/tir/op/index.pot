"m = te.var(\"m\")\n"
"mysum = te.comm_reducer(lambda x, y: x+y,\n"
"    lambda t: tvm.tir.const(0, dtype=t), name=\"mysum\")\n"
"A = te.placeholder((n, m), name=\"A\")\n"
"k = te.reduce_axis((0, m), name=\"k\")\n"
